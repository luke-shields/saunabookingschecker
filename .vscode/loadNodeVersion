#!/usr/bin/env zsh
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
NVMRC_PATH="$ROOT_DIR/.nvmrc"

if [[ ! -f "$NVMRC_PATH" ]]; then
  echo "Error: .nvmrc not found at $NVMRC_PATH" >&2
  exit 1
fi

export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
if [[ -s "$NVM_DIR/nvm.sh" ]]; then
  . "$NVM_DIR/nvm.sh"
else
  echo "Error: nvm not found. Expected at $NVM_DIR/nvm.sh" >&2
  exit 1
fi

NODE_VERSION="$(tr -d '[:space:]' < "$NVMRC_PATH")"
if [[ -z "$NODE_VERSION" ]]; then
  echo "Error: .nvmrc is empty" >&2
  exit 1
fi

nvm use --silent "$NODE_VERSION" >/dev/null

if [[ $# -eq 0 ]]; then
  echo "Usage: .vscode/loadNodeVersion <command> [args...]" >&2
  exit 1
fi

exec "$@"
