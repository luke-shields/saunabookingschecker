{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Sauna: scrape booking data",
      "type": "shell",
      "command": "zsh",
      "args": [
        "-lc",
        "${workspaceFolder}/.vscode/loadNodeVersion npm run scrape:booking-data"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Sauna: push bookings to database",
      "type": "shell",
      "command": "zsh",
      "args": [
        "-lc",
        "${workspaceFolder}/.vscode/loadNodeVersion npm run push:bookings:db"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Sauna: sync csvs",
      "type": "shell",
      "command": "zsh",
      "args": [
        "-lc",
        "${workspaceFolder}/.vscode/loadNodeVersion npm run sync:csvs"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Sauna: update (sync csvs + scrape booking data + push bookings to database)",
      "type": "shell",
      "command": "zsh",
      "args": [
        "-lc",
        "${workspaceFolder}/.vscode/loadNodeVersion npm run update"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
