{
  "version": "2.0.0",
  "inputs": [
    {
      "id": "saunaName",
      "type": "promptString",
      "description": "Sauna name (must match SaunaName in csvs/sauna_info.csv). Use ALL (or leave blank) to scrape everything.",
      "default": "ALL"
    }
  ],
  "tasks": [
    {
      "label": "Sauna: scrape booking data",
      "type": "shell",
      "command": "zsh",
      "args": [
        "-lc",
        "${workspaceFolder}/.vscode/loadNodeVersion npm run scrape:booking-data"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Sauna: scrape booking data (prompt for sauna)",
      "type": "shell",
      "command": "zsh",
      "args": [
        "-lc",
        "SAUNA=\"${input:saunaName}\"; if [[ -z \"$SAUNA\" || \"$SAUNA\" == \"ALL\" ]]; then ${workspaceFolder}/.vscode/loadNodeVersion npm run scrape:booking-data; else ${workspaceFolder}/.vscode/loadNodeVersion npm run scrape:booking-data -- --sauna \"$SAUNA\"; fi"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Sauna: push bookings to database",
      "type": "shell",
      "command": "zsh",
      "args": [
        "-lc",
        "${workspaceFolder}/.vscode/loadNodeVersion npm run push:bookings:db"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Sauna: sync csvs",
      "type": "shell",
      "command": "zsh",
      "args": [
        "-lc",
        "${workspaceFolder}/.vscode/loadNodeVersion npm run sync:csvs"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Sauna: update (sync csvs + scrape booking data + push bookings to database)",
      "type": "shell",
      "command": "zsh",
      "args": [
        "-lc",
        "${workspaceFolder}/.vscode/loadNodeVersion npm run update"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
