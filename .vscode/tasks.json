{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Sauna: show node version",
      "type": "shell",
      "command": "zsh",
      "args": [
        "-lc",
        "${workspaceFolder}/.vscode/loadNodeVersion node -v && ${workspaceFolder}/.vscode/loadNodeVersion npm -v"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Sauna: npm install",
      "type": "shell",
      "command": "zsh",
      "args": [
        "-lc",
        "${workspaceFolder}/.vscode/loadNodeVersion npm install"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Sauna: playwright install browsers",
      "type": "shell",
      "command": "zsh",
      "args": [
        "-lc",
        "${workspaceFolder}/.vscode/loadNodeVersion npx playwright install"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Sauna: export html snapshots",
      "type": "shell",
      "command": "zsh",
      "args": [
        "-lc",
        "${workspaceFolder}/.vscode/loadNodeVersion npm run open:urls"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Sauna: harvest json to sqlite",
      "type": "shell",
      "command": "zsh",
      "args": [
        "-lc",
        "${workspaceFolder}/.vscode/loadNodeVersion npm run harvest:sqlite"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Sauna: sync opening times to sqlite",
      "type": "shell",
      "command": "zsh",
      "args": [
        "-lc",
        "${workspaceFolder}/.vscode/loadNodeVersion npm run sync:opening-times"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Sauna: update (sync + scrape + harvest)",
      "type": "shell",
      "command": "zsh",
      "args": [
        "-lc",
        "${workspaceFolder}/.vscode/loadNodeVersion npm run update"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Sauna: load and harvest",
      "dependsOn": [
        "Sauna: export html snapshots",
        "Sauna: harvest json to sqlite"
      ],
      "dependsOrder": "sequence"
    },
    {
      "label": "Sauna: setup + export html",
      "dependsOn": [
        "Sauna: show node version",
        "Sauna: npm install",
        "Sauna: playwright install browsers",
        "Sauna: export html snapshots"
      ],
      "dependsOrder": "sequence"
    }
  ]
}
