{
  "name": "sauna-bookings-checker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "scrape:booking-data": "node playwrite_scripts/open_urls.js",
    "push:bookings:db": "node scripts/harvest_to_sqlite.js",
    "update": "node scripts/update.js",
    "generate:scraper": "node scripts/generate_scraper.js",
    "export:data": "node scripts/export_data.js",
    "serve:docs": "npm run export:data && live-server docs --port=8080 --watch=docs/data",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "dotenv": "^16.5.0",
    "better-sqlite3": "^11.8.1",
    "csv-parse": "^5.6.0",
    "playwright": "^1.52.0"
  },
  "devDependencies": {
    "live-server": "^1.2.2",
    "vitest": "^2.1.9"
  }
}
